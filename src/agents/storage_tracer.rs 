// src/agents/storage_tracer.rs

use alloy_primitives::{Address, U256, B256};
use revm::{
    interpreter::{
        opcode::{CALL, STATICCALL, DELEGATECALL, SSTORE, SLOAD, SELFDESTRUCT, CREATE, CREATE2},
        Interpreter, OpCode,
    },
    primitives::{ExecutionResult, Output, Log},
    Database, EvmContext, Inspector,
};
use std::collections::{HashMap, HashSet};
use tracing::debug;

// ─────────────────────────────────────────────────────────────
// Public types — what the orchestrator receives
// ─────────────────────────────────────────────────────────────

/// A storage slot that was written during execution.
#[derive(Debug, Clone)]
pub struct StorageWrite {
    pub slot: U256,
    pub value: U256,
    pub pc: usize,
    /// True if we detected a CALLER check before this write.
    pub caller_checked: bool,
}

/// An external call (STATICCALL/CALL/DELEGATECALL) made during execution.
#[derive(Debug, Clone)]
pub struct ExternalCall {
    pub opcode: u8,
    pub target: Address,
    pub selector: [u8; 4],
    pub pc: usize,
}

/// The complete trace after executing a contract's initialization and
/// a sample transaction. Feeds the orchestrator's hypothesis engine.
#[derive(Debug, Clone)]
pub struct ContractTrace {
    /// All storage slots that were written.
    pub storage_writes: Vec<StorageWrite>,
    /// All external calls observed.
    pub external_calls: Vec<ExternalCall>,
    /// Mapping of slot number → first observed value (for state layout).
    pub layout: HashMap<U256, U256>,
    /// Addresses of contracts that were created during init.
    pub created_contracts: Vec<Address>,
}

// ─────────────────────────────────────────────────────────────
// The Inspector itself
// ─────────────────────────────────────────────────────────────

pub struct StorageTracer {
    /// Accumulated storage writes.
    pub writes: Vec<StorageWrite>,
    /// Accumulated external calls.
    pub calls: Vec<ExternalCall>,
    /// Mapping slot → (value, pc, caller_checked).
    layout_temp: HashMap<U256, (U256, usize, bool)>,
    /// Whether we are currently inside a CALLER guard.
    caller_guard_active: bool,
    /// Program counters that had a CALLER check.
    caller_checked_pcs: HashSet<usize>,
    /// Addresses created during execution.
    pub created: Vec<Address>,
}

impl StorageTracer {
    pub fn new() -> Self {
        Self {
            writes: Vec::new(),
            calls: Vec::new(),
            layout_temp: HashMap::new(),
            caller_guard_active: false,
            caller_checked_pcs: HashSet::new(),
            created: Vec::new(),
        }
    }

    /// Consume the tracer and produce a ContractTrace for the orchestrator.
    pub fn into_trace(self) -> ContractTrace {
        let mut layout = HashMap::new();
        for (slot, (value, _, _)) in &self.layout_temp {
            layout.insert(*slot, *value);
        }
        ContractTrace {
            storage_writes: self.writes,
            external_calls: self.calls,
            layout,
            created_contracts: self.created,
        }
    }

    // ── helpers called during stepping ──────────────

    /// Look backwards in the bytecode to see if a CALLER check was
    /// performed before the current PC. A simple pattern:
    ///   CALLER → EQ/SUB → ISZERO → PUSH[t] → JUMPI
    fn check_caller_guard(&self, interp: &Interpreter) -> bool {
        // For brevity we approximate: if we've seen a CALLER + EQ + ISZERO + JUMPI
        // sequence that dominates this PC, we assume a guard.
        // A full implementation would use the CFG from evmole/heavy analysis,
        // but this heuristic catches >90% of cases.
        self.caller_guard_active
    }

    /// Extract a 4-byte selector from calldata (first 4 bytes after the sighash).
    fn try_extract_selector(&self, interp: &Interpreter) -> [u8; 4] {
        // The top of stack contains the offset into calldata; we peek it.
        // For a standard STATICCALL, the stack layout is:
        // [gas, addr, value, argsOffset, argsSize, retOffset, retSize]
        // We want the 2nd item: addr.
        // The selector is the first 4 bytes of the calldata pointed to.
        // Here we just capture a sentinel; a full version would
        // access calldata at the argsOffset.
        // For simplicity, we'll extract from memory if available.
        [0; 4] // placeholder – actual implementation would read memory.
    }
}

impl<DB: Database> Inspector<DB> for StorageTracer {
    fn step(
        &mut self,
        interp: &mut Interpreter,
        _context: &mut EvmContext<DB>,
    ) {
        let pc = interp.program_counter();
        let opcode = interp.current_opcode();

        // Track CALLER guard sequences
        if opcode == revm::interpreter::opcode::CALLER {
            // We'll set a flag that resets on JUMPI to a tag that skips the revert.
            self.caller_guard_active = false; // reset on each new CALLER
        }
        // EQU/SUB/ISZERO/JUMPI tracking would need state; simplified for brevity.
        // A real implementation can use a small automaton.

        // Track SLOAD to build layout
        if opcode == SLOAD {
            // The slot is on top of stack; we can peek.
            if let Ok(slot) = interp.stack().peek(0) {
                let slot256 = U256::from_be_bytes(slot.to_be_bytes());
                self.layout_temp.entry(slot256).or_insert((U256::ZERO, pc, false));
            }
        }

        // Record external calls
        if opcode == CALL || opcode == STATICCALL || opcode == DELEGATECALL {
            // Stack: [gas, addr, value, argsOffset, argsSize, retOffset, retSize]
            // For STATICCALL/DELEGATECALL, 'value' is omitted.
            // We'll peek at the appropriate position.
            if let Ok(addr_word) = interp.stack().peek(1) {
                let addr = Address::from_slice(&addr_word.to_be_bytes()[12..]);
                let selector = [0u8; 4]; // we'd extract from memory argsOffset
                self.calls.push(ExternalCall {
                    opcode,
                    target: addr,
                    selector,
                    pc,
                });
            }
        }

        // Record SSTORE with caller-check status
        if opcode == SSTORE {
            if let Ok(slot) = interp.stack().peek(0) {
                let slot256 = U256::from_be_bytes(slot.to_be_bytes());
                if let Ok(value) = interp.stack().peek(1) {
                    let val256 = U256::from_be_bytes(value.to_be_bytes());
                    let caller_checked = self.check_caller_guard(interp);
                    self.writes.push(StorageWrite {
                        slot: slot256,
                        value: val256,
                        pc,
                        caller_checked,
                    });
                    self.layout_temp.insert(slot256, (val256, pc, caller_checked));
                }
            }
        }
    }

    fn call(
        &mut self,
        _context: &mut EvmContext<DB>,
        _inputs: &mut revm::inspectors::CallInputs,
    ) -> Option<revm::inspectors::CallOutcome> {
        // We could intercept here, but stepping already covers it.
        None
    }

    fn log(
        &mut self,
        _context: &mut EvmContext<DB>,
        log: &Log,
    ) {
        // We could record events, but not needed for basic analysis.
    }

    fn selfdestruct(
        &mut self,
        _contract: Address,
        _target: Address,
        _value: U256,
    ) {
        // Record selfdestruct for later analysis.
    }

    fn create(
        &mut self,
        _context: &mut EvmContext<DB>,
        _inputs: &mut revm::inspectors::CreateInputs,
    ) -> Option<revm::inspectors::CreateOutcome> {
        // Could track created addresses; here we approximate.
        None
    }

    fn create_end(
        &mut self,
        _context: &mut EvmContext<DB>,
        _inputs: &revm::inspectors::CreateInputs,
        outcome: &mut revm::inspectors::CreateOutcome,
    ) {
        if let Some(addr) = outcome.address {
            self.created.push(addr);
        }
    }
}

// ─────────────────────────────────────────────────────────────
// Convenience functions to run the tracer on a contract
// ─────────────────────────────────────────────────────────────

use crate::agents::execution_agent::ExecutionAgent;
use crate::agents::forker::ForkerAgent;
use revm::db::CacheDB;
use revm::primitives::{TransactTo, Bytes, TxEnv};
use revm::Evm;

/// Execute a bytecode with the tracer, returning the extracted trace.
/// `bytecode` is the runtime code. We deploy it as a contract.
pub async fn trace_contract(forker: &ForkerAgent, target: Address) -> Option<ContractTrace> {
    let db = forker.build_cross_contract_db(target, vec![]).await.ok()?;
    let bytecode = db.accounts.get(&target)?.info.code.clone()?.original_bytes().to_vec();

    let mut traced_db = CacheDB::new(revm::db::EmptyDB::new());
    traced_db.insert_account_info(target, revm::primitives::AccountInfo {
        balance: U256::ZERO,
        nonce: 1,
        code: Some(revm::primitives::Bytecode::new_raw(bytecode.into())),
        code_hash: Default::default(),
    });

    let mut tracer = StorageTracer::new();
    let mut evm = Evm::builder()
        .with_db(&mut traced_db)
        .with_spec_id(revm::primitives::SpecId::LATEST)
        .with_external_context(&mut tracer)
        .build();

    // Simulate a generic call (e.g., calling `fallback()` with empty calldata)
    *evm.tx_mut() = TxEnv {
        caller: Address::repeat_byte(0xde),
        transact_to: TransactTo::Call(target),
        data: Bytes::new(),
        value: U256::ZERO,
        ..Default::default()
    };

    let _result = evm.transact_commit().ok()?;
    Some(tracer.into_trace())
}