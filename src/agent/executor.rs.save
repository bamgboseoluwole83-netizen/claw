
impl ExecutorAgent {
    pub fn execute<DB: Database>(chaos_db: ChaosDatabase<DB>, caller: Address, target: Address, calldata: Vec<u8>, value: U256) -> (StateRecorder, bool) {
        info!(target: "executor", "Spinning up REVM CPU...");
        let recorder = StateRecorder::default();
        let mut block_env = BlockEnv::default();
        block_env.number = U256::from(100000);
        block_env.timestamp = U256::from(1000000);
        block_env.basefee = U256::from(1000000000);
        let mut evm = EvmBuilder::default()
            .with_spec_id(SpecId::CANCUN)
            .with_db(chaos_db)
            .with_external_context(recorder)
            .append_handler_register(MainnetHandler::default())
            .modify_tx_env(|tx| {
                tx.caller = caller;
                tx.transact_to = TransactTo::Call(target);
                tx.data = calldata.into();
                tx.value = value;
                tx.gas_limit = 1_000_000_u64;
                tx.nonce = Some(1);
                tx.gas_price = U256::from(1_000_000_000_u64);
            })
            .build();
        let result = evm.transact();
        tracing::warn!(target: "executor", "REVM SUCCESS STATUS: {}", result.is_ok());
        let final_recorder = evm.into_context().external;
        let success = result.is_ok();
        if success {
            info!(target: "executor", "TX SUCCESS! SSTOREs recorded: {}", final_recorder.recorded_state.len());
        } else {
            info!(target: "executor", "TX REVERTED. SSTOREs recorded: {}", final_recorder.recorded_state.len());
        }
        (final_recorder, success)
    }
}
